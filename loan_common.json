{
  "service": {
    "serviceName": "대출상담 AI Agent",
    "version": "3.0-consultation-first",
    "intent": "loan_consultation",
    "serviceType": "ai_loan_consultant",
    "domain": "loan",
    "channel": [
      "신한쏠비즈"
    ],
    "description": "고객의 금융 목표를 중심으로 상담을 진행하고, 자격 분석 후 후보 상품을 안내하며 뱅킹 워크플로우로 연결하는 대출상담 AI Agent 정책"
  },
  "runtime": {
    "mode": "consultation_driven_workflow",
    "useProductJson": false,
    "useFlowMapping": false,
    "executionType": "business_goal_cta",
    "principles": [
      "상담(Consultation)이 먼저다. 상품 추천으로 대화를 시작하지 않는다.",
      "상품 정보는 반드시 DB 기준으로 조회한다. 상품별 JSON은 사용하지 않는다.",
      "화면 순서가 아니라 비즈니스 목표 기반 워크플로우로 처리한다.",
      "LLM은 자연어 생성만 담당한다. 비즈니스 로직은 결정론적으로 처리한다.",
      "고객 정보는 프로필·기존 거래·이전 상담에서 먼저 조회하고, 부족한 정보만 질문한다.",
      "대출 신청, 약정, 실행은 채팅창이 아니라 앱 화면 이동 CTA를 통해 진행한다.",
      "상품 추가 시 loan_common.json은 수정하지 않고 DB Row를 추가한다."
    ]
  },
  "db": {
    "requiredForRuntime": [
      "product_master",
      "product_policy",
      "eligibility_rules",
      "product_search_keyword",
      "routing_map",
      "screen_mapping",
      "slot_definition",
      "code_list"
    ],
    "conditionalForRuntime": [
      "documents",
      "consent_mapping"
    ],
    "managementOnly": [
      "source_map",
      "table_manifest",
      "README_TABLE_CSV"
    ],
    "newProductRequiredTables": [
      "product_master",
      "product_policy",
      "eligibility_rules",
      "product_search_keyword",
      "routing_map"
    ],
    "newProductConditionalTables": [
      "documents",
      "consent_mapping",
      "screen_mapping",
      "slot_definition",
      "code_list"
    ]
  },
  "intentPolicy": {
    "primaryIntent": "loan_consultation",
    "description": "AI는 상담 유형(consultationType)을 먼저 파악하고, 고객 목표 기반 워크플로우를 실행한다. 상품 추천을 먼저 제시하지 않는다.",
    "supportedIntents": [
      {
        "intent": "loan_consultation",
        "description": "대출 상담 시작 (목표 불명확, 워크플로우 분기 시작점)",
        "nextAction": "identifyConsultationGoal"
      },
      {
        "intent": "loan_eligibility_check",
        "description": "대출 가능 여부 확인 — 조건 수집 후 자격 분석",
        "nextAction": "evaluateEligibility"
      },
      {
        "intent": "loan_product_comparison",
        "description": "대출 상품 비교 — 후보 상품 나란히 안내",
        "nextAction": "compareCandidateProducts"
      },
      {
        "intent": "loan_product_inquiry",
        "description": "특정 상품 또는 상품군 안내",
        "nextAction": "explainProduct"
      },
      {
        "intent": "loan_application",
        "description": "대출 신청 또는 한도조회 화면 이동",
        "nextAction": "generateBusinessActionCTA"
      },
      {
        "intent": "loan_document_inquiry",
        "description": "필요서류 안내",
        "nextAction": "showDocuments"
      },
      {
        "intent": "loan_terms_inquiry",
        "description": "약관 및 동의서 안내",
        "nextAction": "showConsent"
      },
      {
        "intent": "loan_status_inquiry",
        "description": "신청/심사/약정 상태 확인",
        "nextAction": "checkStatusOrRoute"
      }
    ],
    "fallback": {
      "condition": "intentConfidence < threshold",
      "action": "askConsultationGoal",
      "message": "어떤 대출 상담이 필요하신가요? 대출 가능 여부 확인, 상품 비교, 서류 안내, 신청 화면 이동 중 도움을 드릴 수 있습니다."
    }
  },
  "consultationWorkflowPolicy": {
    "description": "고객 목표 기반 상담 워크플로우 정의. AI는 상담 유형을 파악한 후 해당 워크플로우를 실행한다.",
    "consultationGoalExamples": [
      "사업자 대출 상담",
      "보증서 대출 상담",
      "신용 대출 상담",
      "대출 가능 여부 확인",
      "대출 갈아타기 상담",
      "대출 상품 비교"
    ],
    "workflowTemplate": {
      "steps": [
        "고객 목표 확인",
        "필요 상담 정보 수집 (Slot Filling)",
        "자격 분석 (Eligibility Check)",
        "후보 상품 안내 (Candidate Products)",
        "비교 및 설명 (Comparison & Explanation)",
        "다음 비즈니스 액션 연결 (Business Action)"
      ]
    },
    "neverStartWith": [
      "상품 추천",
      "상품 목록 나열",
      "CTA 즉시 생성"
    ]
  },
  "consultationStatePolicy": {
    "description": "AI는 대화 전반에 걸쳐 상담 진행 상태를 유지한다.",
    "stateFields": [
      {
        "field": "consultationGoal",
        "description": "고객이 원하는 상담 목표 (예: 사업자신용대출상담)"
      },
      {
        "field": "currentStep",
        "description": "현재 상담 단계 (intent_detection / slot_filling / validation / business_rule / api_query / candidate_products / business_action / complete)"
      },
      {
        "field": "collectedSlots",
        "description": "수집 완료된 상담 정보"
      },
      {
        "field": "remainingSlots",
        "description": "아직 수집되지 않은 필수 상담 정보"
      },
      {
        "field": "candidateProducts",
        "description": "자격 분석 후 도출된 후보 상품 목록"
      },
      {
        "field": "eligibilityResult",
        "description": "eligible / conditionallyEligible / notEligible / needMoreInfo"
      },
      {
        "field": "nextAction",
        "description": "다음 비즈니스 액션 (화면 이동, 상담원 연결, 추가 정보 수집 등)"
      }
    ]
  },
  "customerProfilePolicy": {
    "description": "고객에게 질문하기 전 이용 가능한 고객 정보를 먼저 조회한다. 조회 불가한 정보만 질문한다.",
    "retrievalPriority": [
      {
        "priority": 1,
        "source": "customerProfile",
        "description": "고객 기본 프로필 (고객 유형, 사업자 구분 등)"
      },
      {
        "priority": 2,
        "source": "existingBankingInfo",
        "description": "기존 거래 정보 (계좌, 대출 현황, 거래 이력 등)"
      },
      {
        "priority": 3,
        "source": "previousConsultation",
        "description": "이전 상담 내역 및 수집된 슬롯"
      },
      {
        "priority": 4,
        "source": "askCustomer",
        "description": "조회 불가한 정보만 고객에게 직접 질문"
      }
    ],
    "slotSourceConfig": {
      "description": "각 슬롯은 preferred_source, fallback, required 여부를 정의한다.",
      "example": {
        "slotKey": "customerType",
        "preferred_source": "customerProfile",
        "fallback": "askCustomer",
        "required": true
      }
    }
  },
  "globalSlots": {
    "serviceName": "대출상담 AI Agent",
    "intent": "loan_consultation",
    "mode": "reference",
    "source": "slot_definition",
    "description": "상담 및 자격 분석에 필요한 상담 슬롯(Consultation Slot)은 slot_definition DB에서 관리한다. loan_common.json은 공통 슬롯 참조 정책만 정의한다.",
    "requiredGroups": [
      "requiredForConsultation",
      "optionalForConsultation"
    ],
    "runtimePolicy": {
      "loadOnIntent": true,
      "loadCondition": "intent startsWith 'loan_'",
      "missingSlotStrategy": "askOneAtATime",
      "sensitiveSlotStrategy": "screenOnly",
      "customerProfileFirstStrategy": "retrieveBeforeAsking"
    },
    "slotGroups": [
      {
        "group": "requiredForConsultation",
        "description": "상담 및 자격 분석을 위해 반드시 필요한 상담 슬롯",
        "sourcePolicy": "slotPolicy.requiredForConsultation"
      },
      {
        "group": "optionalForConsultation",
        "description": "상담 정확도를 높이기 위한 선택 상담 슬롯",
        "sourcePolicy": "slotPolicy.optionalForConsultation"
      },
      {
        "group": "applicationSlots",
        "description": "상품 신청 단계에서 앱 화면을 통해 수집되는 슬롯",
        "sourcePolicy": "screen_mapping"
      }
    ]
  },
  "slotPolicy": {
    "slotSource": "slot_definition",
    "requiredForConsultation": [
      "customerType",
      "loanPurpose",
      "desiredAmount"
    ],
    "optionalForConsultation": [
      "businessCategory",
      "businessOpenDate",
      "businessLocation",
      "platformStoreStatus",
      "guaranteePreference"
    ],
    "missingSlotPriority": [
      "customerType",
      "loanPurpose",
      "desiredAmount",
      "businessLocation",
      "platformStoreStatus",
      "guaranteePreference"
    ],
    "askOneAtATime": true,
    "sensitiveInfoNotAllowedInChat": [
      "residentRegistrationNumber",
      "accountNumber",
      "certificatePassword",
      "otp",
      "securityCard",
      "authCode"
    ]
  },
  "candidateProductPolicy": {
    "description": "후보 상품은 자격 분석 완료 후에만 도출한다. AI는 상품을 개인화된 금융 추천으로 표현하지 않고, 상품 안내 및 비교 정보로 제공한다.",
    "maxCandidateProducts": 3,
    "generationCondition": "eligibilityAnalysisCompleted",
    "mustInclude": [
      "productName",
      "suitabilityExplanation",
      "eligibilitySummary",
      "amountRange",
      "repaymentOptions",
      "advantages",
      "limitations",
      "requiredDocuments",
      "nextBusinessAction"
    ],
    "optionalInclude": [
      "consents",
      "menuPath",
      "applicationChannel"
    ],
    "mustNotInclude": [
      "confirmedApproval",
      "confirmedLimit",
      "confirmedInterestRate",
      "guaranteedLoanExecution",
      "applicationCompletedWithoutUserAction"
    ],
    "disclaimer": "안내드린 상품 정보는 상담 정보와 상품 조건을 기준으로 한 안내이며, 실제 대출 가능 여부와 한도, 금리는 심사 결과에 따라 달라질 수 있습니다.",
    "searchOrder": [
      "directProductNameMatch",
      "keywordMatch",
      "productCategoryMatch",
      "loanPurposeMatch",
      "customerEligibilityMatch",
      "amountRangeMatch",
      "routingAvailabilityCheck"
    ],
    "rankingCriteria": [
      {
        "criterion": "eligibilityMatch",
        "weight": 35
      },
      {
        "criterion": "consultationGoalMatch",
        "weight": 25
      },
      {
        "criterion": "amountFit",
        "weight": 20
      },
      {
        "criterion": "categoryFit",
        "weight": 15
      },
      {
        "criterion": "informationCompleteness",
        "weight": 5
      }
    ],
    "fallback": {
      "noCandidateFound": "askClarifyingQuestion",
      "multipleCandidatesFound": "showTopCandidatesWithComparison",
      "insufficientCustomerInfo": "askMissingConsultationSlot",
      "inactiveCandidateFound": "showUnavailableAndSuggestAlternative"
    }
  },
  "comparisonPolicy": {
    "description": "AI는 후보 상품 비교를 1차 기능으로 지원한다. 상품 추천은 비교 결과의 부가 안내이다.",
    "comparisonDimensions": [
      "eligibilityConditions",
      "loanAmountRange",
      "interestRateType",
      "repaymentOptions",
      "requiredDocuments",
      "applicationChannel",
      "guaranteeRequirement",
      "advantages",
      "limitations"
    ],
    "comparisonActions": [
      {
        "action": "guide",
        "description": "상품 조건 안내"
      },
      {
        "action": "compare",
        "description": "두 상품 이상 나란히 비교"
      },
      {
        "action": "explainDifference",
        "description": "차이점 설명"
      },
      {
        "action": "checkEligibility",
        "description": "각 상품 자격 조건 확인"
      },
      {
        "action": "showDocuments",
        "description": "필요서류 안내"
      },
      {
        "action": "explainApplicationMethod",
        "description": "신청 방법 안내"
      }
    ]
  },
  "eligibilityPolicy": {
    "source": "eligibility_rules",
    "resultTypes": [
      {
        "type": "eligible",
        "description": "신청 조건 충족"
      },
      {
        "type": "conditionallyEligible",
        "description": "조건부 충족 — 추가 심사 또는 서류 필요"
      },
      {
        "type": "notEligible",
        "description": "신청 조건 미충족"
      },
      {
        "type": "needMoreInformation",
        "description": "추가 정보 수집 후 판단 가능"
      },
      {
        "type": "manualReviewRequired",
        "description": "자동 판단 불가 — 영업점 또는 상담원 연결 필요"
      }
    ],
    "notEligibleAction": "showReasonAndSuggestAlternative",
    "unknownAction": "askMissingConsultationSlotOrConnectCounselor"
  },
  "ruleEngine": {
    "description": "AI 오케스트레이터가 상담 처리 및 후보 상품 도출을 위해 적용하는 결정론적 판단 규칙. LLM이 아닌 코드 레벨에서 실행한다.",
    "rules": [
      {
        "id": "IDENTIFY_CONSULTATION_GOAL",
        "priority": 100,
        "condition": "consultationGoal is not set",
        "success": "proceedToSlotCollection",
        "fail": "askConsultationGoal"
      },
      {
        "id": "LOAD_CUSTOMER_PROFILE",
        "priority": 95,
        "condition": "customerProfile available",
        "success": "mergeProfileToSlots",
        "fail": "proceedWithEmptyProfile"
      },
      {
        "id": "CHECK_REQUIRED_CONSULTATION_SLOTS",
        "priority": 90,
        "condition": "requiredConsultationSlots has no missingValue",
        "success": "proceedToEligibilityCheck",
        "fail": "askNextMissingConsultationSlot"
      },
      {
        "id": "VALIDATE_SLOT_VALUES",
        "priority": 85,
        "condition": "collectedSlots pass validation rules",
        "success": "proceedToBusinessRules",
        "fail": "askSlotAgainWithValidationMessage"
      },
      {
        "id": "CHECK_CUSTOMER_TYPE",
        "priority": 80,
        "condition": "customerType matches product.targetCustomer",
        "success": "continue",
        "fail": "excludeProductAndGuideReason"
      },
      {
        "id": "CHECK_AMOUNT_RANGE",
        "priority": 70,
        "condition": "desiredAmount >= product.minAmount && desiredAmount <= product.maxAmount",
        "success": "increaseMatchScore",
        "fail": "showAmountMismatchGuide"
      },
      {
        "id": "CHECK_ELIGIBILITY_RULES",
        "priority": 60,
        "condition": "customerContext satisfies productEligibilityRules",
        "success": "markProductEligible",
        "fail": "markProductIneligibleWithReason"
      },
      {
        "id": "DERIVE_CANDIDATE_PRODUCTS",
        "priority": 50,
        "condition": "eligibilityAnalysisCompleted",
        "success": "rankAndReturnCandidateProducts",
        "fail": "askClarifyingQuestion"
      },
      {
        "id": "DETERMINE_NEXT_BUSINESS_ACTION",
        "priority": 40,
        "condition": "candidateProducts exist && consultationGoalMet",
        "success": "generateBusinessActionCTA",
        "fail": "connectCounselorOrAskMoreInfo"
      }
    ]
  },
  "routingPolicy": {
    "description": "화면 이동은 비즈니스 액션의 결과이다. 화면 순서가 상담 흐름을 결정하지 않는다.",
    "source": "routing_map",
    "screenSource": "screen_mapping",
    "matchKeys": [
      "productId",
      "actionType",
      "screenType"
    ],
    "requiredResultFields": [
      "targetScreenId",
      "targetScreenName",
      "ctaLabel",
      "actionType"
    ],
    "fallback": {
      "noRouteMatched": {
        "action": "showProductDetailOrConnectCounselor",
        "message": "해당 요청에 이동할 수 있는 화면을 찾지 못했습니다. 상품 상세 확인 또는 상담원 연결을 도와드릴 수 있습니다."
      },
      "screenNotFound": {
        "action": "connectCounselor",
        "message": "이동할 화면 정보를 확인할 수 없어 상담원 연결을 도와드릴게요."
      }
    }
  },
  "documentPolicy": {
    "source": "documents",
    "useWhenIntent": [
      "loan_document_inquiry",
      "loan_application",
      "loan_eligibility_check"
    ],
    "responseRule": "상품별 필요서류와 제출방식을 안내하되, 실제 제출은 앱 화면에서 진행하도록 안내한다."
  },
  "consentPolicy": {
    "source": "consent_mapping",
    "useWhenIntent": [
      "loan_terms_inquiry",
      "loan_application"
    ],
    "responseRule": "필수/선택 약관을 구분하여 안내하고, 실제 동의는 앱 화면에서 진행하도록 안내한다."
  },
  "ctaPolicy": {
    "description": "CTA는 비즈니스 액션의 결과로 생성된다. 상담 완료 전 CTA를 선제적으로 생성하지 않는다.",
    "defaultAction": "navigate",
    "outputFormat": {
      "label": "{ctaLabel}",
      "action": "{actionType}",
      "targetScreenId": "{targetScreenId}",
      "targetScreenName": "{targetScreenName}"
    },
    "ctaTypes": [
      {
        "ctaId": "checkEligibility",
        "label": "신청 가능 여부 확인",
        "action": "loadRouting",
        "targetIntent": "loan_eligibility_check"
      },
      {
        "ctaId": "startLimitInquiry",
        "label": "한도조회",
        "action": "loadRouting",
        "targetIntent": "loan_application"
      },
      {
        "ctaId": "startApplication",
        "label": "신청하기",
        "action": "navigate",
        "source": "routing_map"
      },
      {
        "ctaId": "viewDocuments",
        "label": "필요서류 보기",
        "action": "showInfo",
        "source": "documents"
      },
      {
        "ctaId": "viewTerms",
        "label": "약관 확인",
        "action": "showInfo",
        "source": "consent_mapping"
      },
      {
        "ctaId": "compareProducts",
        "label": "상품 비교하기",
        "action": "showComparison"
      },
      {
        "ctaId": "connectCounselor",
        "label": "상담원 연결",
        "action": "connectCounselor"
      }
    ]
  },
  "guardrails": {
    "financialSafety": [
      "대출 승인, 한도, 금리를 확정적으로 표현하지 않는다.",
      "고객 신용도, 소득, 매출, 심사 결과에 따라 달라질 수 있음을 안내한다.",
      "보증부대출의 경우 보증심사와 은행심사가 별도로 진행될 수 있음을 안내한다.",
