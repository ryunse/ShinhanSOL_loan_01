  "orchestration": {
    "description": "워크플로우 전 LLM을 호출하지 않는다. LLM은 자연어 응답 생성 단계에서만 사용한다.",
    "steps": [
      {
        "order": 1,
        "stepId": "DETECT_INTENT",
        "action": "extractIntentFromUtterance",
        "executor": "deterministic"
