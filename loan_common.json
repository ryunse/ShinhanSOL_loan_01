{
  "service": {
    "serviceName": "대출상담 및 상품추천",
    "version": "2.1-refactored",
    "intent": "loan_consultation_and_recommendation",
    "serviceType": "ai_loan_advisory",
    "domain": "loan",
    "channel": [
      "신한쏠비즈"
    ],
    "description": "사용자 발화를 기반으로 상품 DB를 조회하고 추천·상담·신청 화면 이동 CTA를 생성하는 대출상담 공통 AI 정책"
  },
  "runtime": {
    "mode": "db_driven_routing",
    "useProductJson": false,
    "useFlowMapping": false,
    "executionType": "screen_navigation_cta",
    "principles": [
      "상품별 JSON은 런타임에서 사용하지 않는다.",
      "상품 정보와 정책은 DB를 기준으로 조회한다.",
      "화면 순서가 아니라 사용자 의도 기반 routing_map으로 목적 화면을 결정한다.",
      "대출 신청, 약정, 실행은 채팅창이 아니라 앱 화면 이동 CTA를 통해 진행한다.",
      "상품 추가 시 loan_common.json은 수정하지 않고 DB Row를 추가한다."
    ]
  },
  "db": {
    "requiredForRuntime": [
      "product_master",
      "product_policy",
      "eligibility_rules",
      "product_search_keyword",
      "routing_map",
      "screen_mapping",
      "slot_definition",
      "code_list"
    ],
    "conditionalForRuntime": [
      "documents",
      "consent_mapping"
    ],
    "managementOnly": [
      "source_map",
      "table_manifest",
      "README_TABLE_CSV"
    ],
    "newProductRequiredTables": [
      "product_master",
      "product_policy",
      "eligibility_rules",
      "product_search_keyword",
      "routing_map"
    ],
    "newProductConditionalTables": [
      "documents",
      "consent_mapping",
      "screen_mapping",
      "slot_definition",
      "code_list"
    ]
  },
  "intentPolicy": {
    "primaryIntent": "loan_consultation",
    "supportedIntents": [
      {
        "intent": "loan_recommendation",
        "description": "조건에 맞는 대출상품 추천",
        "nextAction": "recommendProducts"
      },
      {
        "intent": "loan_product_inquiry",
        "description": "특정 상품 또는 상품군 안내",
        "nextAction": "explainProduct"
      },
      {
        "intent": "loan_application",
        "description": "대출 신청 또는 한도조회 화면 이동",
        "nextAction": "generateRoutingCTA"
      },
      {
        "intent": "loan_eligibility_check",
        "description": "신청 가능 여부 확인",
        "nextAction": "checkEligibility"
      },
      {
        "intent": "loan_document_inquiry",
        "description": "필요서류 안내",
        "nextAction": "showDocuments"
      },
      {
        "intent": "loan_terms_inquiry",
        "description": "약관 및 동의서 안내",
        "nextAction": "showConsent"
      },
      {
        "intent": "loan_status_inquiry",
        "description": "신청/심사/약정 상태 확인",
        "nextAction": "checkStatusOrRoute"
      }
    ],
    "fallback": {
      "condition": "intentConfidence < threshold",
      "action": "askClarifyingQuestion",
      "message": "대출상품 추천, 신청 가능 여부 확인, 필요서류 안내, 신청 화면 이동 중 어떤 도움이 필요하신가요?"
    }
  },
  "globalSlots": {
    "serviceName": "대출상담 및 상품추천",
    "intent": "loan_consultation_and_recommendation",
    "mode": "reference",
    "source": "slot_definition",
    "description": "추천 및 신청에 필요한 Slot은 slot_definition DB에서 관리한다. loan_common.json은 공통 Slot 참조 정책만 정의한다.",
    "requiredGroups": [
      "requiredForRecommendation",
      "optionalForRecommendation"
    ],
    "runtimePolicy": {
      "loadOnIntent": true,
      "loadCondition": "intent startsWith 'loan_'",
      "missingSlotStrategy": "askOneAtATime",
      "sensitiveSlotStrategy": "screenOnly"
    },
    "slotGroups": [
      {
        "group": "requiredForRecommendation",
        "description": "상품 추천을 위해 반드시 필요한 Slot",
        "sourcePolicy": "slotPolicy.requiredForRecommendation"
      },
      {
        "group": "optionalForRecommendation",
        "description": "추천 정확도를 높이기 위한 선택 Slot",
        "sourcePolicy": "slotPolicy.optionalForRecommendation"
      },
      {
        "group": "applicationSlots",
        "description": "상품 신청 단계에서 screen_mapping 또는 실제 앱 화면을 통해 수집되는 Slot",
        "sourcePolicy": "screen_mapping"
      }
    ]
  },
  "slotPolicy": {
    "slotSource": "slot_definition",
    "requiredForRecommendation": [
      "customerType",
      "loanPurpose",
      "desiredAmount"
    ],
    "optionalForRecommendation": [
      "businessCategory",
      "businessOpenDate",
      "businessLocation",
      "platformStoreStatus",
      "guaranteePreference"
    ],
    "missingSlotPriority": [
      "customerType",
      "loanPurpose",
      "desiredAmount",
      "businessLocation",
      "platformStoreStatus",
      "guaranteePreference"
    ],
    "askOneAtATime": true,
    "sensitiveInfoNotAllowedInChat": [
      "residentRegistrationNumber",
      "accountNumber",
      "certificatePassword",
      "otp",
      "securityCard",
      "authCode"
    ]
  },
  "productSearchPolicy": {
    "searchOrder": [
      "directProductNameMatch",
      "keywordMatch",
      "productCategoryMatch",
      "loanPurposeMatch",
      "customerEligibilityMatch",
      "amountRangeMatch",
      "routingAvailabilityCheck"
    ],
    "sources": [
      "product_master",
      "product_search_keyword",
      "product_policy",
      "eligibility_rules",
      "routing_map"
    ],
    "rankingCriteria": [
      {
        "criterion": "intentMatch",
        "weight": 30
      },
      {
        "criterion": "eligibilityMatch",
        "weight": 30
      },
      {
        "criterion": "amountFit",
        "weight": 15
      },
      {
        "criterion": "categoryFit",
        "weight": 15
      },
      {
        "criterion": "informationCompleteness",
        "weight": 10
      }
    ],
    "fallback": {
      "noProductMatched": "askClarifyingQuestion",
      "multipleProductsMatched": "showTopCandidates",
      "insufficientCustomerInfo": "askMissingSlotQuestion",
      "inactiveProductMatched": "showUnavailableAndSuggestAlternative"
    }
  },
  "eligibilityPolicy": {
    "source": "eligibility_rules",
    "resultTypes": [
      "eligible",
      "notEligible",
      "needMoreInformation",
      "manualReviewRequired",
      "consultationRequired"
    ],
    "notEligibleAction": "showReasonAndSuggestAlternative",
    "unknownAction": "askMissingSlotOrConnectCounselor"
  },
  "ruleEngine": {
    "description": "AI 오케스트레이터가 상품 추천 및 CTA 생성을 위해 적용하는 공통 판단 규칙",
    "rules": [
      {
        "id": "CHECK_PRODUCT_DIRECT_MATCH",
        "priority": 100,
        "condition": "utterance contains productName or productKeyword",
        "success": "loadProductByKeyword",
        "fail": "goToProductRecommendation"
      },
      {
        "id": "CHECK_REQUIRED_SLOTS",
        "priority": 90,
        "condition": "requiredSlots has no missingValue",
        "success": "proceedToProductMatching",
        "fail": "askMissingSlotQuestion"
      },
      {
        "id": "CHECK_CUSTOMER_TYPE",
        "priority": 80,
        "condition": "customerType matches product.targetCustomer",
        "success": "continue",
        "fail": "excludeProductAndGuideReason"
      },
      {
        "id": "CHECK_AMOUNT_RANGE",
        "priority": 70,
        "condition": "desiredAmount >= product.minAmount && desiredAmount <= product.maxAmount",
        "success": "increaseMatchScore",
        "fail": "showAmountMismatchGuide"
      },
      {
        "id": "CHECK_ELIGIBILITY_RULES",
        "priority": 60,
        "condition": "customerContext satisfies productEligibilityRules",
        "success": "markProductEligible",
        "fail": "markProductIneligibleWithReason"
      },
      {
        "id": "CHECK_ROUTE_BY_INTENT_AND_PRODUCT",
        "priority": 50,
        "condition": "productId != null && intent != null",
        "success": "loadRoutingMap",
        "fail": "askClarifyingQuestion"
      },
      {
        "id": "CHECK_SCREEN_MAPPING",
        "priority": 40,
        "condition": "targetScreenId exists in screen_mapping",
        "success": "loadScreenMapping",
        "fail": "fallbackToProductDetailOrCounselor"
      }
    ]
  },
  "recommendationPolicy": {
    "maxRecommendedProducts": 3,
    "mustInclude": [
      "productName",
      "recommendationReason",
      "eligibilitySummary",
      "amountRange",
      "repaymentOptions",
      "nextCTA"
    ],
    "optionalInclude": [
      "documents",
      "consents",
      "menuPath"
    ],
    "mustNotInclude": [
      "confirmedApproval",
      "confirmedLimit",
      "confirmedInterestRate",
      "guaranteedLoanExecution",
      "applicationCompletedWithoutUserAction"
    ],
    "disclaimer": "추천 결과는 입력하신 정보와 상품 조건을 기준으로 한 안내이며, 실제 대출 가능 여부와 한도, 금리는 심사 결과에 따라 달라질 수 있습니다."
  },
  "routingPolicy": {
    "source": "routing_map",
    "screenSource": "screen_mapping",
    "matchKeys": [
      "intent",
      "productId",
      "actionType"
    ],
    "requiredResultFields": [
      "targetScreenId",
      "targetScreenName",
      "ctaLabel",
      "actionType"
    ],
    "fallback": {
      "noRouteMatched": {
        "action": "showProductDetailOrConnectCounselor",
        "message": "해당 요청에 바로 이동할 수 있는 화면을 찾지 못했습니다. 상품 상세를 먼저 확인하거나 상담원 연결을 도와드릴 수 있습니다."
      },
      "screenNotFound": {
        "action": "connectCounselor",
        "message": "이동할 화면 정보를 확인할 수 없어 상담원 연결을 도와드릴게요."
      }
    }
  },
  "documentPolicy": {
    "source": "documents",
    "useWhenIntent": [
      "loan_document_inquiry",
      "loan_application",
      "loan_eligibility_check"
    ],
    "responseRule": "상품별 필요서류와 제출방식을 안내하되, 실제 제출은 앱 화면에서 진행하도록 안내한다."
  },
  "consentPolicy": {
    "source": "consent_mapping",
    "useWhenIntent": [
      "loan_terms_inquiry",
      "loan_application"
    ],
    "responseRule": "필수/선택 약관을 구분하여 안내하고, 실제 동의는 앱 화면에서 진행하도록 안내한다."
  },
  "ctaPolicy": {
    "defaultAction": "navigate",
    "outputFormat": {
      "label": "{ctaLabel}",
      "action": "{actionType}",
      "targetScreenId": "{targetScreenId}",
      "targetScreenName": "{targetScreenName}"
    },
    "ctaTypes": [
      {
        "ctaId": "viewProductDetail",
        "label": "상품 자세히 보기",
        "action": "navigate",
        "source": "routing_map"
      },
      {
        "ctaId": "checkEligibility",
        "label": "신청 가능 여부 확인",
        "action": "loadRouting",
        "targetIntent": "loan_eligibility_check"
      },
      {
        "ctaId": "startLimitInquiry",
        "label": "한도조회",
        "action": "loadRouting",
        "targetIntent": "loan_application"
      },
      {
        "ctaId": "startApplication",
        "label": "신청하기",
        "action": "navigate",
        "source": "routing_map"
      },
      {
        "ctaId": "viewDocuments",
        "label": "필요서류 보기",
        "action": "showInfo",
        "source": "documents"
      },
      {
        "ctaId": "viewTerms",
        "label": "약관 확인",
        "action": "showInfo",
        "source": "consent_mapping"
      },
      {
        "ctaId": "connectCounselor",
        "label": "상담원 연결",
        "action": "connectCounselor"
      }
    ]
  },
  "guardrails": {
    "financialSafety": [
      "대출 승인, 한도, 금리를 확정적으로 표현하지 않는다.",
      "고객 신용도, 소득, 매출, 심사 결과에 따라 달라질 수 있음을 안내한다.",
      "보증부대출의 경우 보증심사와 은행심사가 별도로 진행될 수 있음을 안내한다.",
      "필수 약관 및 동의 없이 신청 완료 또는 실행 완료로 안내하지 않는다."
    ],
    "privacy": [
      "주민등록번호, 계좌번호, 휴대폰번호 등 민감정보는 마스킹 처리한다.",
      "공동인증서 비밀번호, OTP, 보안카드 정보는 채팅창에서 요청하지 않는다.",
      "고객정보는 상담 목적과 신청 진행에 필요한 범위 내에서만 사용한다."
    ],
    "executionControl": [
      "대출 신청, 약정, 실행은 사용자 명시적 확인 후 화면 이동 CTA로 진행한다.",
      "챗봇은 대출 실행 결과를 임의로 생성하지 않고 API 결과 또는 화면 상태를 기준으로 안내한다.",
      "챗봇은 실제 금융거래를 채팅창에서 완료 처리하지 않는다."
    ],
    "sourceControl": [
      "상품 조건, 한도, 금리, 서류, 약관은 DB에 등록된 값을 우선 사용한다.",
      "DB에 없는 조건은 추정하지 않는다.",
      "상품 정책 변경 가능성이 있는 항목은 최신 DB 기준으로 응답한다."
    ]
  },
  "orchestration": [
    {
      "order": 1,
      "stepId": "UNDERSTAND_UTTERANCE",
      "action": "extractIntentAndSlots"
    },
    {
      "order": 2,
      "stepId": "SEARCH_PRODUCT",
      "action": "searchProductCatalog"
    },
    {
      "order": 3,
      "stepId": "CHECK_REQUIRED_SLOTS",
      "action": "checkRequiredSlots"
    },
    {
      "order": 4,
      "stepId": "CHECK_POLICY",
      "action": "loadProductPolicy"
    },
    {
      "order": 5,
      "stepId": "CHECK_ELIGIBILITY",
      "action": "evaluateEligibilityRules"
    },
    {
      "order": 6,
      "stepId": "RANK_PRODUCTS",
      "action": "rankProducts"
    },
    {
      "order": 7,
      "stepId": "LOAD_ROUTING",
      "action": "loadRoutingMap"
    },
    {
      "order": 8,
      "stepId": "LOAD_SCREEN",
      "action": "loadScreenMapping"
    },
    {
      "order": 9,
      "stepId": "GENERATE_RESPONSE",
      "action": "generateResponseAndCTA"
    }
  ],
  "chatbotFlow": {
    "description": "대출상담 및 상품추천 AI의 챗봇 기준 처리 순서. 채팅방 내에서 실제 신청을 완료하지 않고, 상품 추천과 화면 이동 CTA 생성을 수행한다.",
    "steps": [
      {
        "order": 1,
        "id": "UNDERSTAND_INTENT",
        "label": "사용자 발화 분석",
        "action": "extractIntentAndSlots"
      },
      {
        "order": 2,
        "id": "LOAD_PRODUCT_DB",
        "label": "상품 DB 조회",
        "action": "searchProductCatalog"
      },
      {
        "order": 3,
        "id": "LOAD_GLOBAL_SLOTS",
        "label": "공통 Slot 로드",
        "action": "loadSlotDefinition"
      },
      {
        "order": 4,
        "id": "COLLECT_REQUIRED_SLOTS",
        "label": "필수 정보 수집",
        "action": "askMissingSlotQuestion"
      },
      {
        "order": 5,
        "id": "CHECK_ELIGIBILITY",
        "label": "신청 가능 조건 확인",
        "action": "evaluateEligibilityRules"
      },
      {
        "order": 6,
        "id": "RANK_PRODUCTS",
        "label": "상품 추천",
        "action": "rankProducts"
      },
      {
        "order": 7,
        "id": "LOAD_ROUTING",
        "label": "화면 Routing 조회",
        "action": "loadRoutingMap"
      },
      {
        "order": 8,
        "id": "LOAD_SCREEN_MAPPING",
        "label": "Screen Mapping 조회",
        "action": "loadScreenMapping"
      },
      {
        "order": 9,
        "id": "GENERATE_CTA",
        "label": "화면 이동 CTA 생성",
        "action": "generateNavigationCTA"
      }
    ]
  },
  "flowSummary": {
    "description": "대출상담 AI 공통 처리 흐름 요약. 화면 순서 기반 플로우가 아니라 사용자 의도 기반 DB 조회 및 화면 이동 CTA 생성 흐름이다.",
    "steps": [
      {
        "order": 1,
        "label": "사용자 발화",
        "description": "대출 추천, 상품 문의, 신청 가능 여부, 필요서류, 약관, 신청 화면 이동 의도 감지"
      },
      {
        "order": 2,
        "label": "Intent 분석",
        "description": "loan_recommendation, loan_product_inquiry, loan_application 등 하위 의도 판단"
      },
      {
        "order": 3,
        "label": "상품 DB 조회",
        "description": "product_master, product_search_keyword, product_policy 조회"
      },
      {
        "order": 4,
        "label": "Slot 수집",
        "description": "slot_definition 및 slotPolicy 기준 부족 정보 확인"
      },
      {
        "order": 5,
        "label": "신청 가능 조건 확인",
        "description": "eligibility_rules 기준 적합/부적합/추가정보 필요 판단"
      },
      {
        "order": 6,
        "label": "추천상품 산출",
        "description": "rankingCriteria 기준 최대 3개 상품 추천"
      },
      {
        "order": 7,
        "label": "Routing Map 조회",
        "description": "intent, productId, actionType 기준 targetScreenId와 ctaLabel 조회"
      },
      {
        "order": 8,
        "label": "Screen Mapping 조회",
        "description": "targetScreenId 기준 화면명, 화면유형, 팝업 여부 등 확인"
      },
      {
        "order": 9,
        "label": "CTA 생성",
        "description": "신한쏠비즈 앱 화면 이동용 CTA 생성"
      }
    ]
  },
  "runtimeOutput": {
    "fields": [
      "intent",
      "confidence",
      "productId",
      "productName",
      "eligibilityResult",
      "recommendationReason",
      "missingSlots",
      "documents",
      "consents",
      "targetScreenId",
      "targetScreenName",
      "ctaLabel",
      "actionType",
      "disclaimer"
    ]
  }
}