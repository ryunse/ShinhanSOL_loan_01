        "order": 2,
        "stepId": "SELECT_CONSULTATION_WORKFLOW",
        "action": "identifyConsultationGoalAndSelectWorkflow",
        "executor": "deterministic"
      },
      {
        "order": 3,
        "stepId": "LOAD_CUSTOMER_PROFILE",
        "action": "retrieveCustomerProfileAndBankingInfo",
        "executor": "api",
        "fallback": "proceedWithEmptyProfile"
      },
      {
        "order": 4,
        "stepId": "INITIALIZE_CONSULTATION_STATE",
        "action": "initOrResumeConsultationState",
        "executor": "deterministic"
      },
      {
        "order": 5,
        "stepId": "FILL_CONSULTATION_SLOTS",
        "action": "extractAndMergeSlots",
        "executor": "deterministic",
        "loop": "askOneAtATime until allRequiredSlotsFilled"
      },
      {
        "order": 6,
        "stepId": "VALIDATE_SLOTS",
        "action": "validateConsultationSlotValues",
        "executor": "deterministic",
        "onFail": "askSlotAgainWithMessage"
      },
      {
        "order": 7,
        "stepId": "EVALUATE_BUSINESS_RULES",
        "action": "evaluateEligibilityRules",
        "executor": "deterministic",
