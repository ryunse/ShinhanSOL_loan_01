        "order": 8,
        "stepId": "QUERY_API",
        "action": "searchProductCatalogAndPolicy",
        "executor": "api",
        "sources": ["product_master", "product_policy", "product_search_keyword"]
      },
      {
        "order": 9,
        "stepId": "ANALYZE_CANDIDATE_PRODUCTS",
        "action": "rankAndFilterCandidateProducts",
        "executor": "deterministic"
      },
      {
        "order": 10,
        "stepId": "DETERMINE_BUSINESS_ACTION",
        "action": "loadRoutingMapAndGenerateCTA",
        "executor": "deterministic",
        "source": "routing_map"
      },
      {
        "order": 11,
        "stepId": "GENERATE_NATURAL_RESPONSE",
        "action": "generateConsultationResponse",
        "executor": "llm",
        "note": "LLM은 이 단계에서만 호출된다."
      }
    ]
  },
